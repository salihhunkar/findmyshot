[Unit]
Description=FindMyShot FastAPI Service
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/findmyshot/backend
EnvironmentFile=/opt/findmyshot/deploy/env/backend.env
ExecStart=/opt/findmyshot/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
