APP_DEBUG=false
ENVIRONMENT=production
DATABASE_URL=sqlite:////opt/findmyshot-data/findmyshot.db
PUBLIC_BASE_URL=https://example.com
CORS_ORIGINS=["https://example.com","https://www.example.com"]
JWT_SECRET_KEY=CHANGE_ME_STRONG_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Mail settings (fill later)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=FindMyShot
SMTP_USE_TLS=true

# Object storage (fill if using S3/R2)
STORAGE_BUCKET_NAME=
STORAGE_REGION=auto
STORAGE_ENDPOINT_URL=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Face matching settings
FACE_MATCH_THRESHOLD=0.45
FACE_MATCH_LIMIT=12
